  "keyFeatures": [
    "Console-driven menu for selecting operations",
    "Export unassigned crew members to a CSV file",
    "Process XML mission operations files and update database records",
    "Query and display missions initiated in a given year",
    "JDBC connectivity to MySQL with configurable properties",
    "DAO pattern with JDBC implementations for Missions, Crew, Ships, and Celestial Bodies",
    "Custom exception handling with error codes and originating class",
    "Jackson XML mapper for parsing ESA operation XML feeds"
  ],
